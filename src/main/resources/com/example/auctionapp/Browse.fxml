                        <Insets bottom="20.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </FlowPane>
               </content>
            </ScrollPane>
            <VBox fx:id="emptyRecentPane" alignment="CENTER" prefHeight="1089.0" prefWidth="1296.0" spacing="15.0">
               <children>
                  <Region prefHeight="200.0" prefWidth="200.0">
                     <styleClass>
                        <String fx:value="icon-1" />
                        <String fx:value="screen-icon" />
                     </styleClass>
                  </Region>
                  <Label alignment="CENTER" prefHeight="39.0" prefWidth="324.0" style="-fx-text-fill: linear-gradient(from 0% 0% to 100% 0%, #7c3aed, #4f46e5);" text="There are no active auction currently" textFill="#888888">
