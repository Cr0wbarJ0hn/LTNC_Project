<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="875.0" prefWidth="1265.0" spacing="20.0" style="-fx-background-color: #16161f;" styleClass="modern-card" stylesheets="@../../../style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>

        <VBox spacing="5.0">
            <children>
                <Label text="My bids" textFill="#fafbff">
                    <font>
                        <Font name="Segoe UI Semibold" size="28.0" />
                    </font>
                </Label>
                <Label fx:id="greetingLabel" prefHeight="27.0" prefWidth="386.0" text="See all the auctions you have participate in here" textFill="#888888">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </children>
        </VBox>
      <Separator prefWidth="200.0" />

                                            <Label text="All bids" textFill="#e4e4e4">
            <font>
                <Font name="Segoe UI Emoji" size="26.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Label>

        <VBox spacing="15.0">
            <children>
                <HBox spacing="20.0" />
            </children>
        </VBox>

        <StackPane VBox.vgrow="ALWAYS">
            <children>

                <ScrollPane fx:id="recentScrollPane" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #F4F6F9;">
                    <content>
                        <VBox fx:id="recentItemsContainer" spacing="15.0" />
                    </content>
                </ScrollPane>

                <VBox fx:id="emptyRecentPane" alignment="CENTER" prefHeight="169.0" prefWidth="878.0" spacing="15.0">
                    <children>
                  <Region prefHeight="200.0" prefWidth="200.0">
                     <styleClass>
                        <String fx:value="screen-icon" />
                        <String fx:value="icon-gavels" />
                     </styleClass>
                     <VBox.margin>
                        <Insets bottom="30.0" />
                     </VBox.margin>
                  </Region>
                        <Label prefHeight="35.0" prefWidth="399.0" style="-fx-text-fill: linear-gradient(from 0% 0% to 100% 0%, #7c3aed, #4f46e5);" text="You currently doesnt participate in any active bid" textFill="#888888">
                            <font>
                                <Font size="18.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

            </children>
        </StackPane>
    </children>
</VBox>
