      <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
   </padding>
   <children>
      <VBox spacing="5.0">
         <children>
            <Label fx:id="categoryTitleLabel" text="categoryTitleLabel" textFill="#cdcdcd">
               <font>
                  <Font name="Segoe UI Semibold" size="28.0" />
               </font>
            </Label>
         </children>
      </VBox>
      <Separator prefWidth="200.0" />
      <Label text="All active auctions" textFill="#e4e4e4">
         <font>
            <Font name="Segoe UI Emoji" size="26.0" />
         </font>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
      <VBox spacing="15.0" />
      <StackPane VBox.vgrow="ALWAYS">
         <children>
            <ScrollPane fx:id="recentScrollPane" fitToWidth="true" prefHeight="930.0" prefWidth="820.0" style="-fx-background-color: transparent; -fx-background: transparent;">
               <content>
                  <FlowPane fx:id="recentItemsContainer" hgap="100.0" prefWrapLength="900.0" vgap="25.0">
