<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" style="-fx-background-color: #13131B;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #20202E; -fx-background-radius: 10;">
            <children>
                <TextField fx:id="searchField" prefHeight="40.0" prefWidth="400.0" promptText="Filter by email, username, or ID..." style="-fx-background-color: #13131B; -fx-text-fill: white; -fx-border-color: #2b2b3c; -fx-border-radius: 5;" />
                <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="deleteButton" mnemonicParsing="false" styleClass="action-button" text="Delete" />
                <Button fx:id="refreshButton" mnemonicParsing="false" styleClass="action-button" text="Refresh" />
            </children>
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
        </HBox>

        <TableView fx:id="dataTable" stylesheets="@../../../style.css" VBox.vgrow="ALWAYS">
            <columns>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>
